# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.next-*.log
current_page.html
debug.html
out.css
test.css
.tmp/

# env files (can opt-in for committing if needed)
.env*
# Tetap commit template env supaya developer baru tahu var apa yang dibutuhkan.
!.env*.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# editors / IDE
.vscode/
.idea/
*.swp
.DS_Store

# Cascade / Windsurf agent skill cache (per-machine, not source code)
.windsurf/
.agents/
.claude/
